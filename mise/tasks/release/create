#!/usr/bin/env python3
#MISE description="Create a GitHub release with the packaged artifact"
"""mise task: release:create — verify the tag, package, and publish via gh."""

import argparse
import logging
import os
import sys

sys.path.insert(
    0, os.path.join(os.environ["MISE_PROJECT_ROOT"], "mise", "lib", "python")
)

from mise_tasks import release  # noqa: E402
from mise_tasks.logging_setup import configure_logging  # noqa: E402

log = logging.getLogger("release.create")


def main() -> None:
    configure_logging()
    parser = argparse.ArgumentParser(
        description="Create a GitHub release with the packaged artifact"
    )
    parser.add_argument("--tag", help="Release tag, e.g. v0.1.0 (or RELEASE_TAG)")
    parser.add_argument("--title", help="Release title (or RELEASE_TITLE)")
    parser.add_argument("--notes", help="Release notes (or RELEASE_NOTES)")
    args = parser.parse_args()

    tag = release.resolve_tag(args.tag)
    title = args.title or os.environ.get("RELEASE_TITLE") or tag
    notes = args.notes or os.environ.get("RELEASE_NOTES")

    log.info("Starting release:create for %s", tag)
    release.verify_tag(tag)
    artifact = release.package(tag)
    release.create_release(tag, title, notes, artifact)
    log.info("Published release %s", tag)


if __name__ == "__main__":
    main()
