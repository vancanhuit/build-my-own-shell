#!/usr/bin/env python3
#MISE description="Dry-run a release without publishing"
"""mise task: release:dry-run — build and package, then show the release plan."""

import argparse
import logging
import os
import sys

sys.path.insert(
    0, os.path.join(os.environ["MISE_PROJECT_ROOT"], "mise", "lib", "python")
)

from mise_tasks import release  # noqa: E402
from mise_tasks.logging_setup import configure_logging  # noqa: E402

log = logging.getLogger("release.dry_run")


def main() -> None:
    configure_logging()
    parser = argparse.ArgumentParser(description="Dry-run a release without publishing")
    parser.add_argument("--tag", help="Release tag, e.g. v0.1.0")
    parser.add_argument("--title", help="Release title (defaults to the tag)")
    parser.add_argument("--notes", help="Release notes (defaults to generated notes)")
    args = parser.parse_args()

    tag = release.resolve_tag(args.tag)
    title = args.title or os.environ.get("RELEASE_TITLE") or tag
    notes = args.notes or os.environ.get("RELEASE_NOTES")

    log.info("Starting release:dry-run for %s", tag)
    artifact = release.package(tag)

    planned = release.release_command(tag, title, notes, artifact)
    log.info("Dry run only; not publishing")
    log.info("Would run: %s", " ".join(planned))
    print(f"Dry run complete. Artifact: {artifact}")


if __name__ == "__main__":
    main()
